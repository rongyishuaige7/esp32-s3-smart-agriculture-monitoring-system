<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SmartAgriculture.Views"
        x:Class="SmartAgriculture.Views.MainWindow"
        Title="智能农业环境监测教学原型"
        Width="900" Height="620"
        Background="{StaticResource BackgroundLight}">
  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0" Background="{StaticResource PrimaryGreen}" Padding="16,12">
      <StackPanel Spacing="3">
        <TextBlock Text="🌿 智能农业环境监测教学原型" FontSize="18" FontWeight="Bold" Foreground="White"/>
        <TextBlock Text="示例数据（非真机）；公开默认不连接网络、不控制设备。" Foreground="#E8F5E9"/>
      </StackPanel>
    </Border>
    <views:MonitorView Grid.Row="1" DataContext="{Binding MonitorViewModel}"/>
  </Grid>
</Window>
